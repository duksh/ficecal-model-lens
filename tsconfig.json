{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/src/*": [
        "src/*"
      ]
    },
    "lib": [
      "ES2017",
      "ES2021",
      "WebWorker",
      "DOM"
    ],
    "module": "esnext",
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}